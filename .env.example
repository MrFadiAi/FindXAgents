# FindX Environment Configuration
#
# Legend:
#   REQUIRED  — App will not start or core features will break without this
#   OPTIONAL  — Feature degrades gracefully when missing; no crashes
#

# ─── Infrastructure (REQUIRED) ───────────────────────────────────────────────

# PostgreSQL database
DATABASE_URL=postgresql://findx:findx@localhost:5432/findx

# Redis for BullMQ job queues
REDIS_URL=redis://localhost:6379

# ─── AI (REQUIRED — needed for email generation, analysis, agent pipeline) ───

GLM_API_KEY=
GLM_BASE_URL=https://api.z.ai/api/anthropic
GLM_MODEL=glm-5.1

# ─── Email Sending (OPTIONAL — emails saved as drafts when missing) ───────────
# When RESEND_API_KEY is not set, outreach emails are generated and saved
# but not actually sent. Set this to enable real email delivery.

# RESEND_API_KEY=re_xxxxxxxxxxxxx
# EMAIL_FROM=hello@example.com

# ─── Dutch Business Sources (OPTIONAL — discovery uses web_search instead) ───
# These are paid APIs. When not configured, discovery falls back to the
# agent pipeline's web_search (SearXNG, self-hosted) which is free.

# KVK_API_KEY=
# GOOGLE_MAPS_API_KEY=

# ─── Server ───────────────────────────────────────────────────────────────────

PORT=3001
NODE_ENV=development

# ─── Browser / Rendering (OPTIONAL — falls back to Chromium) ─────────────────

LIGHTPANDA_URL=http://localhost:9222

# ─── SearXNG (OPTIONAL — self-hosted, used by web_search tool) ───────────────
# If SearXNG is not running, web_search returns an error message instead
# of crashing. Run `docker run -p 8080:8080 searxng/searxng` to start.

# SEARXNG_URL=http://localhost:8080
